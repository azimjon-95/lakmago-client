# ===== LokmaGo Client (mijoz webapp) sozlamalari =====
# Bu faylni .env deb nusxalang:  cp .env.example .env

# Backend API manzili. Agar bo'sh qoldirsangiz — vite proxy /api ni ishlatadi
# yoki mock ma'lumot bilan ishlaydi.
VITE_API_URL=http://localhost:4000/api

# Socket.IO (real-time buyurtma kuzatuvi) manzili
VITE_SOCKET_URL=http://localhost:4000
