# ===== LokmaGo Webapp (mijoz) sozlamalari =====

# Backend API manzili (majburiy — mock rejim yo'q, faqat real backend):
VITE_API_URL=http://127.0.0.1:4000/api

# Socket.IO (real-time buyurtma kuzatuvi)
VITE_SOCKET_URL=http://127.0.0.1:4000

# ===== ULASHISH (SHARE) uchun =====
# Bot username (@ siz) va Mini App nomi — taom ulashish havolasi uchun.
# Havola: https://t.me/<BOT_USERNAME>/<WEBAPP_NAME>?startapp=dish_<id>
VITE_BOT_USERNAME=lakmagobot
# Mini App qisqa nomi. Agar sizда "t.me/lakmagobot?startapp" (nomsiz) ishlasa —
# BO'SH qoldiring. Agar "t.me/lakmagobot/lokmago" bo'lsa — nomni yozing.
VITE_WEBAPP_NAME=

# Chiroyli ulashish (Open Graph rasm+nom karta) uchun SERVER domenи.
#
# DIQQAT: bu yerга t.me havolаси YOZILMAYDI! Faqat backend domenи.
#   ✓ TO'G'RI:   https://api.lokmago.uz
#   ✗ NOTO'G'RI: https://t.me/lakmagobot?startapp
#
# Bo'sh qoldirsangiz — oddiy Mini App havolаси ishlatiladi:
#   t.me/lakmagobot?startapp=dish_<id>   (rasm preview bo'lmaydi, lekin ishlaydi)
VITE_SHARE_BASE=
