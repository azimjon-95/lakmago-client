# ===== LokmaGo Client (mijoz webapp) sozlamalari =====
# cp .env.example .env

# API manzili:
#   'mock'                         -> backend'siz to'liq demo (mock ma'lumot)
#   http://localhost:4000/api      -> haqiqiy backend
#   (bo'sh)                        -> /api (vite proxy orqali backend, bo'lmasa mock)
VITE_API_URL=mock

# Socket.IO (real-time). Demo uchun bo'sh qoldiring — kuzatuv timer bilan simulyatsiya qilinadi.
VITE_SOCKET_URL=
