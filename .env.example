# ===== LokmaGo Webapp (mijoz) sozlamalari =====

# Backend API manzili. Demo uchun 'mock', production'da real backend:
VITE_API_URL=http://localhost:4000/api

# Socket.IO (real-time buyurtma kuzatuvi)
VITE_SOCKET_URL=http://localhost:4000

# ===== ULASHISH (SHARE) uchun =====
# Bot username (@ siz) va Mini App nomi — taom ulashish havolasi uchun.
# Havola: https://t.me/<BOT_USERNAME>/<WEBAPP_NAME>?startapp=dish_<id>
VITE_BOT_USERNAME=LokmaGoBot
VITE_WEBAPP_NAME=app

# Chiroyli ulashish (Open Graph rasm+nom karta) uchun server domenи.
# Bo'sh bo'lsa — to'g'ridan t.me havola (rasm preview bo'lmaydi).
# Masalan: https://api.lokmago.uz
VITE_SHARE_BASE=
